# Electronya Embedded Datastore
# Copyright (C) 2025 by Electronya

config ENYA_DATASTORE
  bool "Electronya Embedded Datastore"
  default y
  depends on CMSIS_RTOS_V2
  help
    The Electronya embedded application datastore.

if ENYA_DATASTORE

config ENYA_DATASTORE_LOG_LEVEL
  int "Electronya Embedded Datastore Log Level"
  default 3
  help
    The Electronya embedded datastore log level.

config ENYA_DATASTORE_MSGQ_TIMEOUT
  int "Datastore Message Queue Get Timeout (ms)"
  default 100
  help
    The timeout for k_msgq_get in the datastore run loop in milliseconds.

config ENYA_DATASTORE_STACK_SIZE
  int "Electronya Datastore Stack Size"
  default 512
  help
    The Electronya datastore service thread stack size in bytes.

config ENYA_DATASTORE_BUFFER_SIZE
  int "Electronya Datastore Command Buffer Size"
  default 32
  help
    The maximum number of Data_t elements that can be read/written
    in a single shell command operation.

config ENYA_DATASTORE_SHELL
  bool "Electronya Datastore Shell Commands"
  default y
  depends on SHELL
  help
    Enable shell commands for the datastore service.
    Provides commands to list, read, and write datapoints for all types:
    binary, button, float, int, multi-state, and uint.

    Commands:
      datastore binary_data ls                    - List binary datapoints
      datastore binary_data read <id> [count]     - Read binary values
      datastore binary_data write <id> <count> <values...> - Write binary values
      (Similar commands available for button, float, int, multi-state, uint)

config ENYA_DATASTORE_MAX_BINARY_SUBS
  int "Electronya Datastore Maximum Binary Subscriptions"
  default 2
  help
    The maximum number of binary datapoint subscriptions.

config ENYA_DATASTORE_MAX_BUTTON_SUBS
  int "Electronya Datastore Maximum Button Subscriptions"
  default 2
  help
    The maximum number of button datapoint subscriptions.

config ENYA_DATASTORE_MAX_FLOAT_SUBS
  int "Electronya Datastore Maximum Float Subscriptions"
  default 2
  help
    The maximum number of float datapoint subscriptions.

config ENYA_DATASTORE_MAX_INT_SUBS
  int "Electronya Datastore Maximum Integer Subscriptions"
  default 2
  help
    The maximum number of signed integer datapoint subscriptions.

config ENYA_DATASTORE_MAX_MULTI_STATE_SUBS
  int "Electronya Datastore Maximum Multi-State Subscriptions"
  default 2
  help
    The maximum number of multi-state datapoint subscriptions.

config ENYA_DATASTORE_MAX_UINT_SUBS
  int "Electronya Datastore Maximum Unsigned Integer Subscriptions"
  default 2
  help
    The maximum number of unsigned integer datapoint subscriptions.

config ENYA_DATASTORE_THREAD_PRIORITY
  int "Electronya Datastore Thread Priority"
  default 5
  help
    The Zephyr preemptible thread priority for the datastore service thread.

config ENYA_DATASTORE_SERVICE_PRIORITY
  int "Electronya Datastore Service Priority"
  default 1
  help
    The service manager priority level for the datastore service.

config ENYA_DATASTORE_HEARTBEAT_INTERVAL_MS
  int "Electronya Datastore Heartbeat Interval (ms)"
  default 1000
  help
    The heartbeat interval in milliseconds for the datastore service.

config FIRST_FLOAT_DEFAULT_VAL
  int "First Float Default Value"
  default 123
  help
    The 1st float default value. Needs to be divided by 10.

config SECOND_INT_DEFAULT_VAL
  int "Second Signed Integer Default Value"
  default -12
  help
    The 2nd signed integer default value.

endif
